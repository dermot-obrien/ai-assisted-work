{
  "name": "aaw-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "aaw-monorepo",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@aaw/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@aaw/protocol": {
      "resolved": "packages/protocol",
      "link": true
    },
    "node_modules/@aaw/skills": {
      "resolved": "packages/skills",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/cli": {
      "name": "@aaw/cli",
      "version": "0.0.0",
      "bin": {
        "aaw": "bin/aaw.js"
      }
    },
    "packages/protocol": {
      "name": "@aaw/protocol",
      "version": "0.0.0",
      "devDependencies": {
        "typescript": "^5.4.0"
      }
    },
    "packages/skills": {
      "name": "@aaw/skills",
      "version": "0.0.0"
    }
  }
}
