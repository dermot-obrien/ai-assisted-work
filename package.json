{
  "name": "ai-assisted-work",
  "version": "2.0.0",
  "description": "AI-Assisted Work (AAW) — domain-agnostic work-management agents + the shared install engine for the AAW framework family.",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Dermot O'Brien",
  "homepage": "https://github.com/dermot-obrien/ai-assisted-work",
  "repository": {
    "type": "git",
    "url": "https://github.com/dermot-obrien/ai-assisted-work.git"
  },
  "bin": {
    "aaw": "./bin/aaw.js"
  },
  "files": [
    "bin/",
    "skills-for-agents/",
    "packages/skills/",
    "framework.manifest.yaml"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "version": "changeset version",
    "release": "npm run build --workspaces --if-present && (cd packages/cli && npm run bundle) && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
