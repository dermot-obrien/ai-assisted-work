{
  "name": "aaw-monorepo",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "aaw": "./bin/aaw.js"
  },
  "files": [
    "bin/",
    "skills-for-agents/",
    "packages/skills/",
    "framework.manifest.yaml"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "version": "changeset version",
    "release": "npm run build --workspaces --if-present && (cd packages/cli && npm run bundle) && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
