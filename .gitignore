# Agent configs that contributors might run against this repo locally —
# don't pollute the repo with one author's tool setup. The shipped tool
# shims live in skills-for-agents/ and packages/skills/.
CLAUDE.md
/.cursor/
/.claude/

# Block .github/ contents EXCEPT the CI workflows that ship with the repo.
/.github/*
!/.github/workflows/

# Private work items (legacy — kept to protect data from pre-v2 setups).
change/work-items-private/
change/work-items-private

# Node / TypeScript build output.
node_modules/
packages/*/dist/
packages/*/node_modules/
*.tsbuildinfo

# Bundled CLI output: bin/aaw.js IS committed (ships in the submodule
# install path; see DEPLOYMENT.md). The sourcemap is regenerated and
# noisy, so it's ignored.
bin/aaw.js.map

# Bundled CLI dependency cache.
.aaw-cache/
